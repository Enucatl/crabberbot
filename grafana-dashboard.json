          "datasource": {"type": "postgres", "uid": "afep0vq6cfls0c"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  regexp_replace(source_url, '^https?://([^/?#]+).*$', '\\1') AS domain,\n  count(*) AS requests,\n  count(DISTINCT chat_id) AS users,\n  ROUND(avg(processing_time_ms)) AS avg_ms\nFROM requests\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 2 DESC\nLIMIT 15",
